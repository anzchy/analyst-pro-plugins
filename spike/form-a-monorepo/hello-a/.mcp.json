{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "jina-ai": {
      "type": "http",
      "url": "https://mcp.jina.ai/v1?include_tools=read_url,search_web,search_arxiv,search_ssrn",
      "headers": {
        "Authorization": "Bearer ${JINA_API_KEY}"
      }
    }
  }
}
